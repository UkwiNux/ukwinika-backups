# =============================================================================
# UKwinika Backup Secrets
# Store this as /etc/ukwinika-backup.secrets with mode 600.
# All sensitive values go HERE, NEVER in the main config.
# =============================================================================

BORG_PASSPHRASE="YourStrongPassphraseHere123!"

# Optional notification secrets (Slack webhook is highly sensitive!)
SLACK_WEBHOOK="https://hooks.slack.com/services/XXXX/YYYY/ZZZZ"

EMAIL_TO="admin@example.com"   # may also be placed in main config if not sensitive
