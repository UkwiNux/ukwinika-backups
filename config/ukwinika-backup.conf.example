# UKwinika Backup Configuration – Example
# Copy to /etc/ukwinika-backup.conf and chmod 600

BACKUP_DIR="/UKwinikaBackup"
REMOVABLE_MOUNT="/media/usb"
BORG_REPO="/UKwinikaBackup/borg_repo"

INCLUDE_DIRS=("/etc" "/home" "/var/www" "/var/lib/mysql" "/var/lib/postgresql")
EXCLUDE_DIRS=("--exclude=/home/*/tmp" "--exclude=/var/cache" "--exclude=/proc" "--exclude=/sys" "--exclude=/dev")

REAL_TIME_DIRS=("/home" "/var/www")

DB_TYPE="mysql"
RETENTION_DAYS=7
RETENTION_VERSIONS=5
STORAGE_THRESHOLD=80

# Change to your work or preferred email address for use.

EMAIL_TO="sysadmin@example.com"
SLACK_WEBHOOK=""

# Optional hooks (make executable)
PRE_BACKUP_HOOK="/usr/local/bin/pre_backup_hook.sh"
POST_BACKUP_HOOK="/usr/local/bin/post_backup_hook.sh"
