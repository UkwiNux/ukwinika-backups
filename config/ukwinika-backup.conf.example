# =============================================================================
# UKwinika Backup Configuration - v2.3
# Copy to /etc/ukwinika-backup.conf and chmod 600
# =============================================================================

# Backup settings
BACKUP_DIR="/UKwinikaBackup"
REMOVABLE_MOUNT="/media/usb"
BORG_REPO="/UKwinikaBackup/borg_repo"

# Which directories to back up
INCLUDE_DIRS="/etc /home /var/www /var/lib/mysql /var/lib/postgresql /opt/oracle"
EXCLUDE_DIRS="--exclude=/home/*/tmp --exclude=/var/cache --exclude=/proc --exclude=/sys --exclude=/dev"

# Retention policy
RETENTION_DAYS=7
RETENTION_VERSIONS=5

# Database settings
DB_TYPE="mysql"                    # mysql, postgresql, oracle
USE_LVM_SNAPSHOT="false"           # Set to "true" if you have LVM volumes for hot snapshots

# Hooks
PRE_BACKUP_HOOK="/etc/ukwinika/pre_backup_hook.sh"
POST_BACKUP_HOOK="/etc/ukwinika/post_backup_hook.sh"

# Prometheus metrics (optional)
PROMETHEUS_FILE="/var/lib/prometheus/node_exporter/custom/ukwinika_backup.prom"

# Other options
STORAGE_THRESHOLD=80               # Percentage threshold for warnings
