# =============================================================================
# UKwinika Backup Configuration Example (idempotent edition)
# Copy to /etc/ukwinika-backup.conf and adjust STRICTLY no secrets here.
# =============================================================================

# ---------- Borg Repository Path (Primary Copy) -----------------------------
BORG_REPO="/UKwinikaBackup/borg-repo"

# ---------- Paths to Back Up (Array) ----------------------------------------
# Default: entire root filesystem (excluding patterns below)
BACKUP_PATHS=("/")

# ---------- Exclude Patterns (Array) ----------------------------------------
# These become `--exclude` arguments for Borg; no other location defines them.
EXCLUDE_DIRS=(
    "/proc" "/sys" "/dev" "/tmp" "/run" "/mnt" "/media" "/lost+found"
    "/var/cache" "/var/tmp" "/home/*/.cache"
)

# ---------- Retention -------------------------------------------------------
RETENTION_DAYS=90             # keep all archives within this many days
RETENTION_VERSIONS=5          # minimum number of versions to keep

# ---------- USB Off‑Site copy (Secondary) -----------------------------------
USB_MOUNT="/mnt/backup_usb"               # mount point
USB_RSYNC_TARGET="/mnt/backup_usb/offsite-borg-repo"   # destination folder on USB

# ---------- Cloud Upload (Tertiary) -----------------------------------------
# rclone remote name and path, e.g. "s3:my-borg-backups"
CLOUD_REMOTE=""

# ---------- Database Dump ---------------------------------------------------
DB_TYPE="none"                 # none, mysql, postgresql, mongodb

# ---------- Hooks -----------------------------------------------------------
PRE_HOOK="/etc/ukwinika/pre_backup_hook.sh"
POST_HOOK="/etc/ukwinika/post_backup_hook.sh"
HOOK_FAIL_ACTION="fatal"      # fatal (stop) or warn (continue)

# ---------- Real‑Time Monitoring Directories --------------------------------
REAL_TIME_DIRS=("/etc" "/home")

# ---------- Notification Recipients (Non‑Secret) ---------------------------
EMAIL_TO="admin@example.com"

# ---------- Prometheus Metrics ----------------------------------------------
METRICS_ENABLED="yes"
PROMETHEUS_FILE="/var/lib/prometheus/node_exporter/custom/ukwinika_backup.prom"
