# /etc/logrotate.d/ukwinika-backup
/var/log/UKwinikaBackup.log
/var/log/UKwinikaBackup_audit.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 640 root adm
    sharedscripts
    postrotate
        if [ -f /var/run/rsyslogd.pid ]; then
            kill -HUP $(cat /var/run/rsyslogd.pid 2>/dev/null) 2>/dev/null || true
        fi
    endscript
}
