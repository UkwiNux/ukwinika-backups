#!/bin/bash
# =============================================================================
# UKwinika Pre-Backup Hook
# Place in /etc/ukwinika/pre_backup_hook.sh and make executable (chmod +x)
# This script is sourced by the main backup – use $? to check previous steps.
# =============================================================================

echo "$(date '+%F %T') [HOOK] Pre-Backup Hook Started" >> /var/log/UKwinikaBackup.log

# Example: stop a service
# systemctl stop apache2

# Example: flush database logs
# mysql -e "FLUSH LOGS;"

echo "$(date '+%F %T') [HOOK] Pre-Backup Hook Completed" >> /var/log/UKwinikaBackup.log
exit 0
